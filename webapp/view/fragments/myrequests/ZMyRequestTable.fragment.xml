<core:FragmentDefinition xmlns:html="http://www.w3.org/1999/xhtml" xmlns:smartTable="sap.ui.comp.smarttable" xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartField="sap.ui.comp.smartfield" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns="sap.m" xmlns:core="sap.ui.core">
   
<Panel headerText="{i18n>xtit.MappingField}" class="sapUiSmallMarginTop" expandable="true" expanded="true">

                        <smartTable:SmartTable
                        entitySet=""
                        smartFilterId=""
                        useExportToExcel="true"
                        useTablePersonalisation="true"
                        header="{i18n>tblHeader}"
                        placeToolbarInTable="true"
                        tableType="ResponsiveTable"
                        showRowCount="true"
                        enableAutoBinding="false"
                        class="sapUiResponsiveContentPadding"
                        demandPopin="true"
                        displayInline="false"
                        useVariantManagement="true"
                        persistencyKey="badDebtTablePersKey"
                       
                    >
                        <smartTable:customToolbar>
                            <Toolbar design="Transparent" >
                                <ToolbarSpacer />
                                <Button text="{i18n>modifyAttachments}" type="Emphasized" press="onAttachUpload" enabled="false" />
                                <Button text="{i18n>sndApproval}" type="Emphasized" press="onApproval" enabled="false" />
                            </Toolbar>
                        </smartTable:customToolbar>
                        <Table  class="sapUiTinyMarginTop" mode="None" selectionChange="onItemSelect" growing="true" growingScrollToLoad="true" updateFinished="onTableCheckBoxEnable" sticky="ColumnHeaders,HeaderToolbar" selectAll="onSelectAll">
                            <columns>
                                <Column>
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "DocumentNo","columnIndex":"1", "autoColumnWidth":"true", "leadingProperty": "DocumentNo", "sortProperty": "DocumentNo", "additionalProperty": "Key,DocAttached,Message,ArrearsInDaya"}' />
                                    </customData>
                                   <Text text="{i18n>xtit.Field}"/>
                                </Column>
                                <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "ProfitCenter", "autoColumnWidth": true, "columnIndex":"2",  "leadingProperty": "ProfitCenter", "sortProperty": "ProfitCenter"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.TotalMappungs}"/>
                                </Column>
                                 <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "CompanyCode", "autoColumnWidth": true, "columnIndex":"3",  "leadingProperty": "CompanyCode", "sortProperty": "CompanyCode"}' />
                                    </customData>
                                   <Text text="{i18n>xtit.PendingRequests}"/>
                                </Column>
                                <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "CompanyCode", "autoColumnWidth": true, "columnIndex":"4",  "leadingProperty": "CompanyCode", "sortProperty": "CompanyCode"}' />
                                    </customData>
                                   <Text text="{i18n>xtit.TargetSystem}"/>
                                </Column>
                           
                            </columns>
                            <items>
                                <ColumnListItem  vAlign="Middle">
                                        
                                        <cells>
                                            <Text  text="{ProfitCenter}" />
                                        </cells>
                                        <cells>
                                         <Text text="{CompanyCode}" />
                                        </cells>
                                        <cells>
                                            <Text text="{CustomerAccount}" />
                                        </cells>
                                       
                                </ColumnListItem>
                            </items>
                        </Table>
                    </smartTable:SmartTable>
</Panel>
</core:FragmentDefinition>