<core:FragmentDefinition xmlns:html="http://www.w3.org/1999/xhtml" xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartField="sap.ui.comp.smartfield" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns="sap.m" xmlns:core="sap.ui.core">
   
<HBox wrap="Wrap" class="sapUiSmallMargin">
        <GenericTile header="{i18n>xtit.TotalMappings}" subheader="{i18n>xtit.AllActiveRecords}" press=".onNavToMain" class="sapUiSmallMargin">
            <TileContent>
                <NumericContent value="{dashboard>/totalMappings}" icon="sap-icon://database"/>
            </TileContent>
        </GenericTile>
        <GenericTile header="{i18n>xtit.PendingRequests}" subheader="{i18n>xtit.AwaitingApproval}" press=".onNavToApproval" class="sapUiSmallMargin">
            <TileContent>
                <NumericContent value="{dashboard>/totalPending}" valueColor="Critical" icon="sap-icon://pending"/>
            </TileContent>
        </GenericTile>
        <GenericTile header="{i18n>xtit.ApprovedToday}" subheader="{i18n>xtit.ProcessedToday}" press=".onNavToAudit" class="sapUiSmallMargin">
            <TileContent>
                <NumericContent value="{dashboard>/approvedToday}" valueColor="Good" icon="sap-icon://accept"/>
            </TileContent>
        </GenericTile>
        <GenericTile header="{i18n>xtit.RejectedToday}" subheader="{i18n>xtit.DeclinedToday}" press=".onNavToAudit" class="sapUiSmallMargin">
            <TileContent>
                <NumericContent value="{dashboard>/rejectedToday}" valueColor="Error" icon="sap-icon://decline"/>
            </TileContent>
        </GenericTile>
        <GenericTile header="{i18n>xtit.MyPending}" subheader="{i18n>xtit.MySubmittedRequests}" press=".onNavToMyRequests" class="sapUiSmallMargin">
            <TileContent>
                <NumericContent value="{dashboard>/myPending}" valueColor="Critical" icon="sap-icon://person-placeholder"/>
            </TileContent>
         </GenericTile>
</HBox>
</core:FragmentDefinition>