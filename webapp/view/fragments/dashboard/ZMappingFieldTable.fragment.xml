<core:FragmentDefinition xmlns:html="http://www.w3.org/1999/xhtml" xmlns:smartTable="sap.ui.comp.smarttable" xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartField="sap.ui.comp.smartfield" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns="sap.m" xmlns:core="sap.ui.core">
   
<Panel headerText="{i18n>xtit.DisputeProcessorMapping}" class="sapUiSmallMarginTop" expandable="true" expanded="true">

                    <smartTable:SmartTable
                        id="idMappingSmartTable"
                        entitySet="Myrequest_DetSet"
                        smartFilterId=""
                        useExportToExcel="true"
                        useTablePersonalisation="true"
                        header="{i18n>xtit.tblHeader}"
                        placeToolbarInTable="true"
                        tableType="ResponsiveTable"
                        showRowCount="true"
                        class="sapUiResponsiveContentPadding"
                        demandPopin="true"
                        displayInline="false"
                        useVariantManagement="true"
                        enableAutoBinding="true"
                        persistencyKey="badDebtTablePersKey"
                        requestAtLeastFields="Vkorg,Vkbur,Prctr,Pcgrp,Spart,Gsber"
                    >
                        <smartTable:customToolbar>
                            <Toolbar design="Transparent" >
                                <ToolbarSpacer />
                                <Button text="{i18n>xtit.ModifyAttachments}" type="Emphasized" press="onAttachUpload" enabled="true" />
                                <Button text="{i18n>xtit.SendForApproval}" type="Emphasized" press="onPressSendForApproval" enabled="true" />
                            </Toolbar>
                        </smartTable:customToolbar>
                        <Table id="idMappingTable"  class="sapUiTinyMarginTop" mode="Multiple" selectionChange="onItemSelect" growing="true" growingScrollToLoad="true" updateFinished="onTableCheckBoxEnable" sticky="ColumnHeaders,HeaderToolbar" selectAll="onSelectAll">
                            <columns>
                                <Column>
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Zrule","columnIndex":"1", "autoColumnWidth":"Zrule", "leadingProperty": "Zrule", "sortProperty": "Zrule", "filterProperty": "Zrule"}' />
                                    </customData>
                                   <Text text="{i18n>xtit.Zrule}"/>
                                </Column>
                                <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Bukrs", "autoColumnWidth": true, "columnIndex":"2",  "leadingProperty": "Bukrs", "sortProperty": "Bukrs", "filterProperty": "Bukrs"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.Bukrs}"/>
                                </Column>
                                 <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Partner", "autoColumnWidth": true, "columnIndex":"3",  "leadingProperty": "Partner", "sortProperty": "Partner", "filterProperty": "Partner"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.Partner}"/>
                                </Column>
                               <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "ReasonCode", "autoColumnWidth": true, "columnIndex":"4",  "leadingProperty": "ReasonCode", "sortProperty": "ReasonCode", "filterProperty": "ReasonCode"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.ReasonCode}"/>
                                </Column>
                                <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "actions", "autoColumnWidth": true, "columnIndex":"5"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.Actions}"/>
                                </Column>
                           
                            </columns>
                            <items>
                                <ColumnListItem  >
                                        <cells>
                                            <Text  text="{Zrule}" />
                                        </cells>
                                        <cells>
                                            <Text  text="{Bukrs}" />
                                        </cells>
                                        <cells>
                                         <Text text="{Partner}" />
                                        </cells>
                                        <cells>
                                            <Text text="{ReasonCode}" />
                                        </cells>
                                        <cells>
                                            <HBox justifyContent="SpaceBetween" alignItems="Center">
                                                <Button icon="sap-icon://accept" type="Accept" press="onPressApprove" />
                                                <Button icon="sap-icon://cancel" type="Reject" press="onPressReject" />
                                            </HBox>
                                        </cells>
                                       
                                </ColumnListItem>
                            </items>
                        </Table>
                    </smartTable:SmartTable>
</Panel>
</core:FragmentDefinition>