<core:FragmentDefinition xmlns:html="http://www.w3.org/1999/xhtml" xmlns:smartTable="sap.ui.comp.smarttable" xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartField="sap.ui.comp.smartfield" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns="sap.m" xmlns:core="sap.ui.core">
   
<Panel headerText="{i18n>xtit.ApprovalRequests}" class="sapUiSmallMarginTop" expandable="true" expanded="true">

                    <smartTable:SmartTable
                        id="idMappingSmartTable"
                        entitySet="Myrequest_DetSet"
                        smartFilterId=""
                        useExportToExcel="true"
                        useTablePersonalisation="true"
                        header="{i18n>xtit.tblHeader}"
                        placeToolbarInTable="true"
                        tableType="ResponsiveTable"
                        showRowCount="true"
                        class="sapUiResponsiveContentPadding"
                        demandPopin="true"
                        displayInline="false"
                        useVariantManagement="true"
                        enableAutoBinding="true"
                        persistencyKey="badDebtTablePersKey"
                        requestAtLeastFields="Vkorg,Vkbur,Prctr,Pcgrp,Spart,Gsber,Status,Bukrs,Approver,ApprovedOn,ApprovedAt,Partner,ReasonCode,CreatedAt,ChangedTime"
                    >
                        <smartTable:customToolbar>
                            <Toolbar design="Transparent" >
                                <ToolbarSpacer />
                                <Button icon="sap-icon://validate" text="{i18n>xtit.SendForApproval}" type="Emphasized" press="onPressMultiApproval" enabled="true" />
                                <Button icon="sap-icon://cancel" text="{i18n>xtit.SendForReject}" type="Emphasized" press="onPressMultiReject" enabled="true" />
                            </Toolbar>
                        </smartTable:customToolbar>
                        <Table id="idMappingTable"  class="sapUiTinyMarginTop" mode="MultiSelect" selectionChange="onItemSelect" growing="true" growingScrollToLoad="true" updateFinished="onTableCheckBoxEnable" sticky="ColumnHeaders,HeaderToolbar" selectAll="onSelectAll">
                            <columns>
                                <Column>
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Zrule","columnIndex":"0", "autoColumnWidth":"Zrule", "leadingProperty": "Zrule", "sortProperty": "Zrule", "filterProperty": "Zrule"}' />
                                    </customData>
                                   <Text text="{i18n>xtit.Zrule}"/>
                                </Column>
                                 <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "OldProcessor", "autoColumnWidth": true, "columnIndex":"1",  "leadingProperty": "OldProcessor", "sortProperty": "OldProcessor", "filterProperty": "OldProcessor"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.OldProcessor}"/>
                                </Column>
                                <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Processor", "autoColumnWidth": true, "columnIndex":"2",  "leadingProperty": "Processor", "sortProperty": "Processor", "filterProperty": "Processor"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.Processor}"/>
                                </Column>
                                
                               <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "CreatedOn", "autoColumnWidth": true, "columnIndex":"3",  "leadingProperty": "CreatedOn", "sortProperty": "CreatedOn", "filterProperty": "CreatedOn"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.CreatedOn}"/>
                                </Column>
                                  <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "ChangedOn", "autoColumnWidth": true, "columnIndex":"4",  "leadingProperty": "ChangedOn", "sortProperty": "CreatedOn", "filterProperty": "ChangedOn"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.ChangedOn}"/>
                                </Column>
                                 <Column >
                                    <customData>
                                        <core:CustomData key="p13nData" value='\{"columnKey": "Actions", "autoColumnWidth": true, "columnIndex":"5"}' />
                                    </customData>
                                    <Text text="{i18n>xtit.Actions}"/>
                                </Column>
                                
                           
                            </columns>
                            <items>
                                <ColumnListItem  >
                                        <cells>
                                            <Text  text="{Zrule}" />
                                        </cells>
                                         <cells>
                                         <Text text="{OldProcessor}" />
                                        </cells>
                                        <cells>
                                         <Text text="{Processor}" />
                                        </cells>
                                        <cells>
                                            <Text  text="{CreatedOn}" />
                                        </cells>
                                       
                                        <cells>
                                            <Text text="{ChangedOn}" />
                                        </cells>
                                        <cells>
                                            <HBox justifyContent="Start" alignItems="Center" class="sapUiTinyMarginBegin">
                                                <Button icon="sap-icon://accept" type="Accept" press="onPressApprove" />
                                                <Button icon="sap-icon://cancel" type="Reject" press="onPressReject" class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                        </cells>
                                       
                                </ColumnListItem>
                            </items>
                        </Table>
                    </smartTable:SmartTable>
</Panel>
</core:FragmentDefinition>