<core:FragmentDefinition xmlns:html="http://www.w3.org/1999/xhtml" xmlns:smartForm="sap.ui.comp.smartform" xmlns:smartField="sap.ui.comp.smartfield" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns="sap.m" xmlns:core="sap.ui.core">
   
<Panel headerText="{i18n>xtit.MappingField}" class="sapUiSmallMarginTop" expandable="true" expanded="true">
    <Table items="{dashboard>/fieldStats}" growing="true" growingThreshold="10" noDataText="{i18n>xtit.NoFiledStatsAvail}">
        <columns>
            <Column>
                <header>
                <Text text="{i18n>xtit.Field}"/>
                </header>
            </Column>
            <Column>
                <header>
                <Text text="{i18n>xtit.TotalMappungs}"/>
                </header>
            </Column>
            <Column>
                <header>
                <Text text="{i18n>xtit.PendingRequests}"/>
                </header>
            </Column>
            <Column>
                <header>
                <Text text="{i18n>xtit.TargetSystem}"/>
                </header>
            </Column>
        </columns>
        <items>
        <ColumnListItem>
            <cells>
                <Text text="{dashboard>fieldName}"/>
                <ObjectStatus text="{dashboard>totalMappings}" state="None"/>
                <ObjectStatus text="{dashboard>pendingCount}" state="{= ${dashboard>pendingCount} > 0 ? 'Warning' : 'Success' }"/>
                <Text text="{dashboard>targetSystems}"/>
            </cells>
        </ColumnListItem>
        </items>
    </Table>
</Panel>
</core:FragmentDefinition>